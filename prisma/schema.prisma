generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  USER
  SUPERADMIN
}

enum ProductCategory {
  STRUCTURES
  LIGHTING
  SOUND
  SCREENS
  TEXTILE
  SPECIAL_EFFECTS
  COMMUTATION
  ADDITIONAL_EQUIPMENT
}

enum MovementType {
  IN
  OUT
  ADJUSTMENT
}

enum MovementSource {
  MANUAL
  SCAN
  EXCEL_IMPORT
  ADMIN_EDIT
}

enum ImportStatus {
  PENDING
  COMPLETED
  FAILED
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  name         String
  passwordHash String
  role         UserRole @default(USER)
  avatarUrl    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  movements       StockMovement[] @relation("MovementUser")
  auditLogs       AuditLog[]
  createdProducts Product[]       @relation("ProductCreatedBy")
  updatedProducts Product[]       @relation("ProductUpdatedBy")
  importBatches   ImportBatch[]   @relation("ImportBatchUser")

  @@index([username])
  @@index([role])
}

model Product {
  id         String          @id @default(cuid())
  name       String
  barcode    String          @unique
  category   ProductCategory @default(ADDITIONAL_EQUIPMENT)
  quantity   Int             @default(0)
  isArchived Boolean         @default(false)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  createdById String?
  updatedById String?

  createdBy User? @relation("ProductCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  updatedBy User? @relation("ProductUpdatedBy", fields: [updatedById], references: [id], onDelete: SetNull)

  movements StockMovement[]

  @@index([barcode])
  @@index([name])
  @@index([category])
  @@index([isArchived])
}

model StockMovement {
  id            String         @id @default(cuid())
  productId     String
  performedById String
  type          MovementType
  source        MovementSource @default(MANUAL)
  quantity      Int
  balanceBefore Int
  balanceAfter  Int
  note          String?
  createdAt     DateTime       @default(now())
  importBatchId String?

  product     Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  performedBy User         @relation("MovementUser", fields: [performedById], references: [id], onDelete: Restrict)
  importBatch ImportBatch? @relation(fields: [importBatchId], references: [id], onDelete: SetNull)

  @@index([productId, createdAt])
  @@index([performedById, createdAt])
  @@index([type])
  @@index([source])
}

model ImportBatch {
  id           String       @id @default(cuid())
  fileName     String
  importedById String
  status       ImportStatus @default(PENDING)
  rowsTotal    Int          @default(0)
  rowsSuccess  Int          @default(0)
  rowsFailed   Int          @default(0)
  reportJson   Json?
  createdAt    DateTime     @default(now())

  importedBy User            @relation("ImportBatchUser", fields: [importedById], references: [id], onDelete: Restrict)
  movements  StockMovement[]

  @@index([importedById, createdAt])
  @@index([status])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@index([entityType, entityId])
  @@index([action])
}